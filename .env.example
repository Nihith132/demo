# API keys / secrets (never commit real values)
GROQ_API_KEY=your_groq_api_key

# Supabase Postgres connection string (example)
# Format: postgresql://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT Auth (doctor login)
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Firebase Auth (patient login)
# Use a Firebase service account JSON (recommended) or individual env vars.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# Supabase Storage (PDF uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=patient-uploads
SUPABASE_SIGNED_URL_EXPIRES_SECONDS=3600
